# Long Chau Care Guide - API Keys Configuration
# ================================================
# Copy this file to .env and fill in your keys.
# NEVER commit the .env file to version control!

# 1. API Keys (SENSITIVE - KEEP SECRET)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# 2. API Configuration
API_TIMEOUT=10
MODEL_TEMPERATURE=0.5
MAX_TOKENS=2048

# AI Models (Lighter models)
GEMINI_MODEL_NAME="gemini-2.5-flash-lite"
OPENAI_MODEL_NAME="gpt-4o-mini"

# 3. Application Toggles
# Cấu hình "True" sẽ cho phép AI trả lời câu hỏi ngoài lề (General knowledge)
ALLOW_OUT_OF_SCOPE=False

# 4. Logging & Server
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000
